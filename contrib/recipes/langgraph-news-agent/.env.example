# .env.example
# ===========================================================
# Environment Variables Template for LangGraph News Agent
# ===========================================================
#
# SETUP INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your real API keys in the .env file
# 3. Never commit the .env file to Git!
#
# ===========================================================

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# OpenAI API Key (for APO optimization)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# NewsAPI Key (for news search tool)
# Get yours at: https://newsapi.org/account
NEWSAPI_KEY=your_newsapi_key_here
